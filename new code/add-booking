<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
  <title>Book a Trip - SAI System</title>
  <link rel="stylesheet" href="styles.css"/>
 
</head>
<body>

<header class="navbar">
  <div class="navbar-inner">
    <a href="user-dashboard.html" class="nav-logo">
      <img src="image/saii.png" alt="SAII Logo" class="logo-img"/>
    </a>
    <nav class="nav-links">
      <a href="user-dashboard.html" class="nav-link" >Dashboard</a>
      <a href="view-trips.html"   class="nav-link">View Trips</a>
      <a href="add-booking.html" class="nav-link active">Book a Trip</a>
      <a href="my-bookings.html" class="nav-link">My Bookings</a>
      <a href="user-heat-map.html" class="nav-link">Heat Map</a>
    </nav>
    <div class="nav-right">
      <span class="role-chip user">&#9679; User</span>
      <span style="color:rgba(255,255,255,.65);font-size:.85rem;" id="user-name">Khalid</span>
      <a href="signin.html" class="btn btn-sm btn-outline-dark">Logout</a>
    </div>
    <button class="nav-toggle" onclick="document.getElementById('nm').classList.toggle('open')" aria-label="Menu">&#9776;</button>
  </div>
  <div class="nav-mobile" id="nm">
    <a href="user-dashboard.html" class="nav-link active">Dashboard</a>
    <a href="view-trips.html"   class="nav-link">View Trips</a>
    <a href="add-booking.html"    class="nav-link">Book a Trip</a>
    <a href="my-bookings.html"    class="nav-link">My Bookings</a>
    <a href="user-heat-map.html"       class="nav-link">Heat Map</a>
    <div class="nav-mobile-footer">
      <a href="signin.html" class="btn btn-sm btn-outline-dark">Logout</a>
    </div>
  </div>
</header>
    
<main class="container">
  <h2>Add Booking</h2>
  <p class="subtitle">Reserve a seat on an available trip</p>
<div class="form-card">
    <div class="form-card-title">
      <i class="fa-regular fa-calendar-plus"></i>
      Booking Details
    </div>

    <div class="form-group">
      <label>Full Name</label>
      <input type="text" id="fullName" placeholder="Enter your full name" />
    </div>

    <div class="form-group">
      <label>Email</label>
      <input type="email" id="email" placeholder="Enter your email" />
    </div>

    <div class="form-group">
      <label>Select Trip</label>
      <select id="tripSelect" onchange="onTripChange()">
        <option value="">Choose a trip...</option>
        <option value="1">Makkah Hotel → Mina | 2026-06-17 07:00 (30 seats)</option>
        <option value="2">Muzdalifah → Mina | 2026-06-16 05:00 (41 seats)</option>
        <option value="3">Mina → Jamarat | 2026-06-16 08:00 (10 seats)</option>
        <option value="4">Jamarat → Makkah Hotel | 2026-06-16 12:00 (48 seats)</option>
        <option value="5">Arafat → Muzdalifah | 2026-06-15 14:30 (19 seats)</option>
        <option value="6">Aziziyah Camp → Arafat | 2026-06-15 05:30 (5 seats)</option>
      </select>
    </div>
  </div>

  <!-- Trip Preview Card (shows after selecting) -->
  <div id="tripPreview" class="trip-preview-card">
    <div class="trip-header">
      <div class="trip-bus-name">
        <i class="fa-solid fa-bus"></i>
        <span id="pvBus">Bus BUS-07</span>
        <span class="trip-id-tag" id="pvId">#TRP-002</span>
      </div>
      <span class="badge-active">active</span>
    </div>
    <div class="trip-route-row">
      <div class="trip-loc"><i class="fa-solid fa-location-dot"></i><span id="pvFrom">Arafat</span></div>
      <div class="route-arrow"><i class="fa-solid fa-arrow-right"></i></div>
      <div class="trip-loc"><i class="fa-solid fa-location-dot"></i><span id="pvTo">Muzdalifah</span></div>
    </div>
    <div class="trip-meta">
      <span><i class="fa-regular fa-calendar"></i><span id="pvDate">Jun 15, 2026</span></span>
      <span><i class="fa-regular fa-clock"></i><span id="pvTime">14:30</span></span>
      <span><i class="fa-solid fa-users"></i><span id="pvSeatsBadge" class="seats-tag good"><span id="pvSeats">19/45 seats</span></span></span>
    </div>
  </div>

  <!-- Confirm Button -->
  <button class="btn-confirm" id="confirmBtn" onclick="confirmBooking()" disabled>
    <i class="fa-solid fa-circle-check"></i>
    <span id="btnText">Confirm Booking</span>
  </button>
</main>

<!-- SUCCESS MODAL -->
<div id="successModal" class="modal">
  <div class="modal-box" style="border-top: 5px solid var(--success);">
    <i class="fa-solid fa-circle-check" style="font-size: 50px; color: var(--success);"></i>
    <h3 style="margin-top: 15px;">Booking Confirmed!</h3>
    <p style="font-size: 14px; color: #666; margin-top: 10px;" id="successMsg"></p>
    <div style="margin: 20px 0; border: 2px dashed #ddd; padding: 20px; display: inline-block;">
      <i class="fa-solid fa-qrcode" style="font-size: 100px;"></i>
      <p id="qrInfo" style="font-weight: bold; font-size: 14px; margin-top: 8px;"></p>
    </div>
    <button class="btn-primary" onclick="hideModals()">Done</button>
  </div>
</div>

<script>
  const trips = {
    "1": { from:"Makkah Hotel", to:"Mina",          date:"Jun 17, 2026", time:"07:00", bus:"Bus BUS-03", id:"#TRP-001", seats:30, total:45 },
    "2": { from:"Muzdalifah",   to:"Mina",          date:"Jun 16, 2026", time:"05:00", bus:"Bus BUS-05", id:"#TRP-003", seats:41, total:45 },
    "3": { from:"Mina",         to:"Jamarat",       date:"Jun 16, 2026", time:"08:00", bus:"Bus BUS-09", id:"#TRP-004", seats:10, total:45 },
    "4": { from:"Jamarat",      to:"Makkah Hotel",  date:"Jun 16, 2026", time:"12:00", bus:"Bus BUS-11", id:"#TRP-005", seats:48, total:50 },
    "5": { from:"Arafat",       to:"Muzdalifah",    date:"Jun 15, 2026", time:"14:30", bus:"Bus BUS-07", id:"#TRP-002", seats:19, total:45 },
    "6": { from:"Aziziyah Camp",to:"Arafat",        date:"Jun 15, 2026", time:"05:30", bus:"Bus BUS-02", id:"#TRP-006", seats:5,  total:45 },
  };

  function onTripChange() {
    const val = document.getElementById("tripSelect").value;
    const preview = document.getElementById("tripPreview");
    const btn = document.getElementById("confirmBtn");

    if (!val) {
      preview.classList.remove("visible");
      btn.disabled = true;
      return;
    }

    const t = trips[val];
    document.getElementById("pvBus").textContent = t.bus;
    document.getElementById("pvId").textContent = t.id;
    document.getElementById("pvFrom").textContent = t.from;
    document.getElementById("pvTo").textContent = t.to;
    document.getElementById("pvDate").textContent = t.date;
    document.getElementById("pvTime").textContent = t.time;
    document.getElementById("pvSeats").textContent = `${t.seats}/${t.total} seats`;

    const badge = document.getElementById("pvSeatsBadge");
    badge.className = "seats-tag";
    if (t.seats <= 5) badge.classList.add("crit");
    else if (t.seats <= 15) badge.classList.add("low");
    else badge.classList.add("good");

    preview.classList.add("visible");
    btn.disabled = (t.seats === 0);
  }

  function confirmBooking() {
    const val = document.getElementById("tripSelect").value;
    if (!val) return;
    const t = trips[val];

    const btn = document.getElementById("confirmBtn");
    btn.disabled = true;
    document.getElementById("btnText").textContent = "Booking...";

    
    setTimeout(() => {
      t.seats--;
      
      document.getElementById("pvSeats").textContent = `${t.seats}/${t.total} seats`;
      
      document.getElementById("qrInfo").textContent = `${t.from} → ${t.to} | ${t.bus}`;
      document.getElementById("successMsg").textContent = `Reservation confirmed for ${t.date} at ${t.time}`;
      
      document.getElementById("successModal").classList.add("active");
      
      document.getElementById("btnText").textContent = "Confirm Booking";
      btn.disabled = false;
    }, 1200);
  }

  function hideModals() {
    document.querySelectorAll('.modal').forEach(m => m.classList.remove('active'));
  }
</script>

  <footer style="border-top:1px solid var(--border);padding:1.25rem 1rem;text-align:center;background:var(--bg);">
    <p class="text-muted text-sm">© 2026 SAII. All rights reserved.</p>
  </footer>

</body>

</html>
